# ─────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in before running docker compose
# ─────────────────────────────────────────────────────────────────────────

# Shared secret for signing API tokens issued by the Streamlit UI.
# Generate a strong value with:   openssl rand -hex 32
SWREQ_API_SECRET=f5abf053784f196d96b333ba2ae92a23c8792666bb09a9fe25bc1f9e1da9f926

# Ollama location (host machine from inside containers)
# On Linux, docker-compose.yml maps host.docker.internal via extra_hosts.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Models (must be pulled into Ollama separately: `ollama pull <model>`)
STAGE1_MODEL=qwen3-coder:30b
STAGE2_MODEL=qwen2.5:latest

# Host-side ports
API_PORT=8000
UI_PORT=8501