# ─────────────────────────────────────────────────────────────────────────
# Dockerfile — swreq Streamlit UI
#
# Serves notebooks/llm_streamlit_app.py on port 8501.
# Talks to the FastAPI container at API_URL (default http://api:8000).
# ─────────────────────────────────────────────────────────────────────────
FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential gcc \
        libffi-dev libssl-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY notebooks/ ./notebooks/
COPY core/      ./core/
COPY src/       ./src/
COPY configs/   ./configs/
COPY data/references/ ./data/references/
COPY manage_users.py  ./
COPY fake_libc_include/ ./fake_libc_include/

ARG HOST_UID=1000
ARG HOST_GID=1000
RUN mkdir -p /app/artifacts/logs /app/data /app/data/C_Parsed && \
    groupadd -g ${HOST_GID} swreq && \
    useradd -u ${HOST_UID} -g ${HOST_GID} -m -s /bin/bash swreq && \
    chown -R swreq:swreq /app
    
USER swreq

EXPOSE 8501

CMD ["streamlit", "run", "notebooks/llm_streamlit_app.py", \
     "--server.port", "8501", \
     "--server.address", "0.0.0.0", \
     "--server.headless", "true", \
     "--browser.gatherUsageStats", "false"]
