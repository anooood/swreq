# ─────────────────────────────────────────────────────────────────────────
# Dockerfile — swreq FastAPI server
#
# Builds a slim image that serves api.app:app on port 8000.
# The Ollama instance is expected to run OUTSIDE this container and be
# reachable via OLLAMA_BASE_URL (see docker-compose.yml).
# ─────────────────────────────────────────────────────────────────────────
FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

# gcc is required by pycparser (C preprocessing).
# libffi/openssl are required by bcrypt on slim images.
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential gcc \
        libffi-dev libssl-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY api/       ./api/
COPY core/      ./core/
COPY src/       ./src/
COPY configs/   ./configs/
COPY data/references/ ./data/references/
COPY manage_users.py  ./
COPY fake_libc_include/ ./fake_libc_include/

# Create directories the app writes to, and a non-root user
ARG HOST_UID=1000
ARG HOST_GID=1000
RUN mkdir -p /app/artifacts/logs /app/data /app/data/C_Parsed && \
    groupadd -g ${HOST_GID} swreq && \
    useradd -u ${HOST_UID} -g ${HOST_GID} -m -s /bin/bash swreq && \
    chown -R swreq:swreq /app

USER swreq

EXPOSE 8000

CMD ["uvicorn", "api.app:app", "--host", "0.0.0.0", "--port", "8000"]
