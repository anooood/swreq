void TestEquipmentSendFuzeStatus(unsigned char ToNodeId)
{
  sFuzeInfo fuze_info;


  ETE_TxMessage.Header.DestinationId = ToNodeId;
  ETE_TxMessage.Header.Opcode = 0x92;
  ETE_TxMessage.Header.DataLength = sizeof(sFuzeInfo);
  ETE_TxMessage.Header.FrameCnt++;

  fuze_info.Type = SS_FUZE.Fuze.Type;
  fuze_info.Mode = SS_FUZE.Fuze.Mode;
  fuze_info.DelayInfo = SS_FUZE.Fuze.FuzeTimeDelay;
  fuze_info.Status = SS_FUZE.Fuze.Status;
  fuze_info.SW_Verion = SS_FUZE.Fuze.SW_Verion;
  fuze_info.SetDelayCmdCnt = SS_FUZE.Fuze.SetDelayCmdCnt;

  memcpy(&ETE_TxMessage.Data, &fuze_info, ETE_TxMessage.Header.DataLength);

  MLAN_Send(ToNodeId, (unsigned char *) &ETE_TxMessage, sizeof(sMLAN_Header) + ETE_TxMessage.Header.DataLength);
}

void TestEquipmentSetFuzeDelay(unsigned char ToNodeId, unsigned char FuzeDelay)
{
  if (!Fuze_SetDelay(FuzeDelay, ToNodeId)) {
    TestEquipmentSendShortMessage(ToNodeId, 0x25);
  }
}

void TestEquipmentHandleRxData(unsigned char *RxData, unsigned int DataLength, unsigned char FromNodeId)
{
  sMLAN_Header *header;


  header = (sMLAN_Header *) RxData;

  switch (header->Opcode) {
    case 0x00 : TestEquipmentSendSBIT(FromNodeId); break;
    case 0x04 : {
      BIT_ClearSBIT();
      BIT_ClearCBIT();
    } break;
    case 0x05 : DisableArcnet = 0xAABBCCDD; break;
    case 0x06 : {
      if (DisableArcnet == 0xAABBCCDD) {
        MLAN_Disable();
      }
    } break;
    case 0x10 : TestEquipmentSendMission(FromNodeId); break;
    case 0x11 : TestEquipmentSendWind(FromNodeId); break;
    case 0x82 : TestEquipmentHandleMission(FromNodeId, RxData); break;
    case 0x83 : TestEquipmentHandleWind(FromNodeId, RxData); break;
    case 0x22 : TestEquipmentClearMission(FromNodeId); break;
    case 0x23 : TestEquipmentClearWind(FromNodeId); break;
    case 0x12 : TestEquipmentSendWeaponConfig(FromNodeId); break;
    case 0x88 : TestEquipmentHandleWeaponConfig(FromNodeId, RxData); break;
    case 0x14 : MCP_SelectGNSS_Antenna((eGNSS_Antenna) RxData[12]); break;
    case 0x16 : TestEquipmentConfigureUBLOX(FromNodeId); break;
    case 0x20 : TestEquipmentForceFullNav(FromNodeId, &RxData[12]); break;
    case 0x30 : TelUseFixedData(*((unsigned int *) &RxData[12])); break;
    case 0x21 : TestEquipmentGNSS_Usage(RxData[12]); break;
    case 0x13 : TestEquipmentSendHealthAndStatus(FromNodeId); break;
    case 0x26 : TestEquipmentSendStackInfo(FromNodeId); break;
    case 0x28 : TestEquipmentHandleBatteryRemainingCapacity(FromNodeId, RxData[12]); break;
    case 0x91 : TestEquipmentSendFuzeStatus(FromNodeId); break;
    case 0x93 : TestEquipmentSetFuzeDelay(FromNodeId, RxData[12]); break;
    default : break;
  }
}
