void WiFiHandleRxData(unsigned char *RxData, unsigned short DataLength)
{
  sMLAN_Header *header;

  WiFi.RxCnt++;
  WiFi.RxTimestamp = Weapon.SystemTime;

  header = (sMLAN_Header *) RxData;

  if (AUXCTRL_SS.WiFiControls.RxDetailAuxOn){
 sprintf(WiFi.AuxStr,"%s%u:Wifi Message Received - OpCode: 0x%x \n",WiFi.AuxStr,GetTimeUs(),header->Opcode);
  }

  if (header->Opcode == (unsigned short)(0xA5)){
   SS_HOBS.HOBSWaitForRxMsg = 0;
  }
  else{
   WiFiWaitForRxMsg = 0;
  }

  switch (header->Opcode) {
    case (unsigned short)(0x01) : WiFiHandleSBIT_Msg((sWiFiSBIT_Msg *) RxData); break;
    case (unsigned short)(0x07) : WiFiHandleBatteryControl(*((unsigned int *) &RxData[12])); break;
    case (unsigned short)(0x08) : WiFiHandleGNSS_Usage((uGNSS_Usage *) &RxData[12]); break;
    case (unsigned short)(0x81) : WiFiHandleStatusMsg((sWiFiStatusMsg *) RxData); break;
    case (unsigned short)(0x10) : WiFiSendMission(); break;
    case (unsigned short)(0x11) : WiFiSendWind(); break;
    case (unsigned short)(0x12) : WiFiHandleClearMissionMsg(); break;
    case (unsigned short)(0x04) : WiFiHandleClearCBIT_Msg(); break;
    case (unsigned short)(0x82) : WiFiHandleMissionMsg((sRawMission *) &RxData[12]); break;
    case (unsigned short)(0x83) : WiFiHandleWindMsg((sWind *) &RxData[12]); break;
    case (unsigned short)(0x90) : WiFiHandleUserLogMsg((sWiFiUserLogMsg *) RxData); break;
    case (unsigned short)(0xA5) : HOBS_HandleRxData((uint8_t *)RxData); break;
    case (unsigned short)(0x5C) : WiFiHandleLogDataMsg((sWiFiLogDataMsg *) RxData); break;
default : break;
  }
}
